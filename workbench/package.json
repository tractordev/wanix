{
  "name": "workbench",
  "displayName": "Workbench",
  "publisher": "wanix",
  "description": "A workbench for code using the workbench from Code - OSS (VS Code)",
  "version": "0.4.0",
  "engines": {
    "vscode": "1.108.2"
  },
  "categories": [
    "Other"
  ],
  "enabledApiProposals": [
    "ipc"
  ],
  "activationEvents": [
    "onFileSystem:wanix"
  ],
  "extensionKind": [
    "web"
  ],
  "browser": "./dist/web/extension.js",
  "scripts": {
    "compile-web": "npm run check-types && go run ./build.go",
    "watch-web": "go run ./build.go --watch",
    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.25.9",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "@progrium/duplex": "^0.2.2"
  },
  "contributes": {
    "commands": [
      {
        "command": "workbench.createTerminal",
        "title": "Create Terminal",
        "category": "Workbench"
      }
    ]
  }
}
